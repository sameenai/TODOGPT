# Daily Briefing — environment variable credentials
# Copy to .env and fill in your values, then: source .env
# Or use direnv: echo "dotenv" >> .envrc && direnv allow
#
# Env vars take precedence over ~/.daily-briefing/config.json.
# NEVER commit .env to version control.

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with "notifications" scope.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── AI summary (Claude) ───────────────────────────────────────────────────────
# Powers the morning summary, daily review, and time-blocking suggestions.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Google (Calendar + Gmail via OAuth) ───────────────────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/
#   → APIs & Services → Credentials → Create Credentials → OAuth client ID
#   → Application type: Web application
#   → Authorized redirect URI: http://localhost:8080/api/auth/google/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Calendar via iCal (alternative to Google OAuth — no setup required) ───────
# Google Calendar: Settings → select calendar → "Secret address in iCal format"
# iCloud: Calendar app → right-click calendar → Share → Public Calendar link
# Outlook: Settings → Calendar → Shared calendars → Publish → ICS link
ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (also set slack.channels and slack.enabled in config).
# Create an app at: https://api.slack.com/apps → OAuth & Permissions → xoxb-...
SLACK_BOT_TOKEN=xoxb-...

# ── Notion ────────────────────────────────────────────────────────────────────
# Internal integration token (also set notion.database_id and notion.enabled in config).
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# ── Jira ─────────────────────────────────────────────────────────────────────
# API token (also set jira.base_url, jira.email, jira.project, jira.enabled in config).
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=...
