# Go backend URL (server-side only — not exposed to browser)
GO_BACKEND_URL=http://localhost:8080

# WebSocket URL (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Anthropic API key — used by the /api/chat route for AI streaming
ANTHROPIC_API_KEY=your_key_here
